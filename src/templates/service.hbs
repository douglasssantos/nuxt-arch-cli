import { $fetch } from 'ofetch'

export interface {{pascalName}}ApiConfig {
  baseUrl?: string
}

export class {{pascalName}}Api {
  private readonly baseUrl: string

  constructor(config: {{pascalName}}ApiConfig = {}) {
    this.baseUrl = config.baseUrl ?? '/api/{{kebabName}}'
  }

  async findAll<T = unknown>(): Promise<T[]> {
    return $fetch<T[]>(this.baseUrl)
  }

  async findById<T = unknown>(id: string | number): Promise<T> {
    return $fetch<T>(`${this.baseUrl}/${id}`)
  }

  async create<T = unknown>(payload: unknown): Promise<T> {
    return $fetch<T>(this.baseUrl, { method: 'POST', body: payload })
  }

  async update<T = unknown>(id: string | number, payload: unknown): Promise<T> {
    return $fetch<T>(`${this.baseUrl}/${id}`, { method: 'PUT', body: payload })
  }

  async remove(id: string | number): Promise<void> {
    await $fetch(`${this.baseUrl}/${id}`, { method: 'DELETE' })
  }
}
