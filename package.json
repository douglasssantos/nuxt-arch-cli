{
  "name": "nuxt-arch-cli",
  "version": "0.1.4",
  "description": "Professional CLI + Nuxt Module for Nuxt 4 projects with DDD, Clean Architecture, Nuxt Layers and Pinia ORM",
  "type": "module",
  "bin": {
    "nxti": "./dist/index.js",
    "nuxti": "./dist/index.js",
    "nuxt-arch": "./dist/index.js",
    "nuxt-arch-cli": "./dist/index.js",
    "nuxi-arch": "./dist/index.js"
  },
  "main": "./dist/module.js",
  "module": "./dist/module.js",
  "exports": {
    ".": {
      "import": "./dist/module.js",
      "types": "./dist/module.d.ts"
    },
    "./runtime/*": "./dist/runtime/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node_modules/.bin/tsc --project tsconfig.json && node scripts/add-shebang.mjs && node scripts/copy-templates.mjs && node scripts/copy-runtime.mjs",
    "postbuild": "node scripts/copy-templates.mjs && node scripts/copy-runtime.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "arch": "node ./dist/index.js",
    "nxti": "nuxt-arch",
    "nuxti": "nuxt-arch",
    "nuxt-arch": "nuxt-arch",
    "nuxt-arch-cli": "nuxt-arch",
    "nuxi-arch": "nuxt-arch"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "chalk": "^5.3.0",
    "change-case": "^5.4.4",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "handlebars": "^4.7.8",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.3.3",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.5.0",
    "@nuxt/schema": "^4.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "keywords": [
    "nuxt",
    "nuxt4",
    "cli",
    "ddd",
    "clean-architecture",
    "pinia",
    "pinia-orm",
    "layers",
    "scaffold",
    "generator"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
